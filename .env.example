# Template de configuration — Copier en .env et remplir les valeurs
# NE PAS commiter .env dans le dépôt git

# Sécurité Django
DJANGO_SECRET_KEY=remplacer-par-une-cle-generee-avec-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=votre-domaine.sn,www.votre-domaine.sn

# Base de données PostgreSQL (prod)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ensmg_archives
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
